rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isActiveStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/healthcarestaff/$(request.auth.uid))
        && get(/databases/$(database)/documents/healthcarestaff/$(request.auth.uid)).data.status == 'Active';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && (request.auth.uid == userId || isActiveStaff());
      allow update, delete: if request.auth != null
        && (request.auth.uid == userId || isActiveStaff());
    }

    function patientProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function patientUserId() {
      return patientProfile().userId;
    }

    function isOwnPatientAppointment() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && resource.data.userId == patientUserId();
    }

    function appointmentHasStaffId() {
      return resource.data.staffId is string
        || resource.data.staffID is string;
    }

    // Patients read `appointments` rows when choosing a slot (`dateTime` + staff).
    function isSlotAvailabilityLookup() {
      return request.auth != null
        && appointmentHasStaffId()
        && resource.data.dateTime is timestamp;
    }

    // Patient claims an open slot document (Available / no userId) → Pending.
    function isPatientClaimAppointmentSlot() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && patientUserId() is string
        && appointmentHasStaffId()
        && resource.data.dateTime is timestamp
        && request.resource.data.dateTime == resource.data.dateTime
        && request.resource.data.userId == patientUserId()
        && request.resource.data.status == 'Pending'
        && request.resource.data.staffId is string
        && (resource.data.status == 'Available'
            || !('userId' in resource.data)
            || resource.data.userId == '');
    }

    // Patient mobile booking: Pending, no location; optional notes / createdAt allowed.
    function isPatientBookingCreate() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && patientUserId() is string
        && request.resource.data.userId == patientUserId()
        && request.resource.data.status == 'Pending'
        && request.resource.data.appointmentId is string
        && request.resource.data.dateTime is timestamp
        && request.resource.data.appointmentType is string
        && request.resource.data.staffId is string;
    }

    match /appointments/{appointmentId} {
      // Single-doc reads (detail screens).
      allow get: if request.auth != null
        && (isActiveStaff() || isOwnPatientAppointment() || isSlotAvailabilityLookup());

      // staffId/staffID + dateTime range (booking: load slots / hide taken times).
      allow list: if request.auth != null
        && (isActiveStaff() || isSlotAvailabilityLookup());

      // userId + dateTime (patient appointment list).
      allow list: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && resource.data.userId == patientUserId();

      allow create: if isActiveStaff() || isPatientBookingCreate();
      allow delete: if isActiveStaff();
      allow update: if isActiveStaff()
        || isPatientClaimAppointmentSlot()
        || (isOwnPatientAppointment()
            && request.resource.data.status == 'Cancelled'
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'updatedAt']));
    }

    function isOwnPatientHealthRecord() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.userId == patientUserId()
            || resource.data.userID == patientUserId());
    }

    function isOwnPatientEmergencyAlert() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.userId == patientUserId()
            || resource.data.userID == patientUserId());
    }

    function isPatientEmergencyAlertCreate() {
      return hasPatientProfile()
        && patientUserId() is string
        && request.resource.data.alertId is string
        && request.resource.data.userId == patientUserId()
        && request.resource.data.alertType is string
        && request.resource.data.status == 'Active'
        && request.resource.data.dateTime is timestamp
        && request.resource.data.location is string;
    }

    function isOwnPatientMedication() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.userId == patientUserId()
            || resource.data.userID == patientUserId());
    }

    function isOwnPatientMedicationReminder() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.userId == patientUserId()
            || resource.data.userID == patientUserId());
    }

    function isPatientMedicationReminderStatusUpdate() {
      return hasPatientProfile()
        && patientUserId() is string
        && isOwnPatientMedicationReminder()
        && request.resource.data.status in ['Pending', 'Completed']
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'completedDate', 'updatedAt']);
    }

    match /medications/{medicationId} {
      allow get: if isActiveStaff() || isOwnPatientMedication();

      allow list: if isActiveStaff();

      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userId == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userID == patientUserId();

      allow create, update, delete: if isActiveStaff();
    }

    match /medicationreminders/{reminderId} {
      allow get: if isActiveStaff() || isOwnPatientMedicationReminder();

      allow list: if isActiveStaff();

      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userId == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userID == patientUserId();

      allow create: if isActiveStaff();
      allow delete: if isActiveStaff();
      allow update: if isActiveStaff() || isPatientMedicationReminderStatusUpdate();
    }

    match /emergencyalerts/{alertId} {
      allow get: if isActiveStaff() || isOwnPatientEmergencyAlert();

      allow list: if isActiveStaff();

      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userId == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userID == patientUserId();

      allow create: if isActiveStaff() || isPatientEmergencyAlertCreate();
      allow update, delete: if isActiveStaff();
    }

    match /healthrecords/{recordId} {
      allow get: if isActiveStaff() || isOwnPatientHealthRecord();

      allow list: if isActiveStaff();

      // Patient app: .where('userId', '==', patientUserId)
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userId == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.userID == patientUserId();

      allow create, update, delete: if isActiveStaff();
    }

    function hasPatientProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPatientConversationParticipant() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.participant1Id == patientUserId()
            || resource.data.participant1ID == patientUserId()
            || resource.data.participant2Id == patientUserId()
            || resource.data.participant2ID == patientUserId());
    }

    function isPatientMessageParty() {
      return hasPatientProfile()
        && patientUserId() is string
        && (resource.data.senderId == patientUserId()
            || resource.data.senderID == patientUserId()
            || resource.data.receiverId == patientUserId()
            || resource.data.receiverID == patientUserId());
    }

    function conversationData(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isPatientInConversationId(conversationId) {
      return hasPatientProfile()
        && patientUserId() is string
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && (
          conversationData(conversationId).participant1Id == patientUserId()
          || conversationData(conversationId).participant1ID == patientUserId()
          || conversationData(conversationId).participant2Id == patientUserId()
          || conversationData(conversationId).participant2ID == patientUserId()
        );
    }

    function isPatientMessageInOwnedConversation() {
      return resource.data.conversationId is string
        && isPatientInConversationId(resource.data.conversationId);
    }

    function isPatientConversationCreate() {
      return hasPatientProfile()
        && patientUserId() is string
        && request.resource.data.status == 'Active'
        && request.resource.data.conversationId is string
        && (request.resource.data.participant1Id == patientUserId()
            || request.resource.data.participant1ID == patientUserId()
            || request.resource.data.participant2Id == patientUserId()
            || request.resource.data.participant2ID == patientUserId());
    }

    function isPatientMessageCreate() {
      return hasPatientProfile()
        && patientUserId() is string
        && request.resource.data.messageId is string
        && request.resource.data.conversationId is string
        && request.resource.data.senderId == patientUserId()
        && request.resource.data.receiverId is string
        && request.resource.data.messageType is string
        && request.resource.data.timestamp is timestamp
        && request.resource.data.deliveryStatus is string
        && (
          (request.resource.data.messageType == 'Text'
            && request.resource.data.content is string)
          || request.resource.data.messageType == 'Voice'
          || request.resource.data.messageType == 'Call'
        );
    }

    function isPatientMessageReceiver() {
      return resource.data.receiverId == patientUserId()
        || resource.data.receiverID == patientUserId();
    }

    function isPatientMarkMessageRead() {
      return hasPatientProfile()
        && patientUserId() is string
        && isPatientMessageReceiver()
        && request.resource.data.deliveryStatus == 'Read'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deliveryStatus', 'readAt', 'deliveredAt']);
    }

    function isStaffMessageSoftDelete() {
      return isActiveStaff()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hiddenFor', 'deletedForEveryone', 'deletedAt', 'deletedBy']);
    }

    function isPatientArchiveConversation() {
      return hasPatientProfile()
        && patientUserId() is string
        && isPatientConversationParticipant()
        && request.resource.data.status == 'Archived'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']);
    }

    function conversationStatusIsArchived() {
      return resource.data.status is string
        && resource.data.status.lower() == 'archived';
    }

    function isPatientUnarchiveConversation() {
      return hasPatientProfile()
        && patientUserId() is string
        && isPatientConversationParticipant()
        && conversationStatusIsArchived()
        && request.resource.data.status == 'Active'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']);
    }

    match /conversations/{conversationId} {
      allow get: if isActiveStaff() || isPatientConversationParticipant();

      // Staff lists Active conversations (filtered client-side).
      allow list: if isActiveStaff();

      // Patient: .where('participant1Id' | 'participant2Id', '==', userId)
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.participant1Id == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.participant1ID == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.participant2Id == patientUserId();
      allow list: if hasPatientProfile()
        && patientUserId() is string
        && resource.data.participant2ID == patientUserId();

      allow create: if isActiveStaff() || isPatientConversationCreate();
      allow update: if isActiveStaff()
        || isPatientArchiveConversation()
        || isPatientUnarchiveConversation();
      allow delete: if isActiveStaff();
    }

    match /messages/{messageId} {
      allow get: if isActiveStaff()
        || isPatientMessageParty()
        || isPatientMessageInOwnedConversation();

      allow list: if isActiveStaff() || isPatientMessageInOwnedConversation();

      allow create: if isActiveStaff() || isPatientMessageCreate();
      allow update: if isActiveStaff()
        || isPatientMarkMessageRead()
        || isStaffMessageSoftDelete();
      allow delete: if isActiveStaff();
    }

    // Patients book appointments: query with .where('status', '==', 'Active').
    match /healthcarestaff/{staffId} {
      allow read: if request.auth != null
        && (request.auth.uid == staffId
            || isActiveStaff()
            || resource.data.status == 'Active');
    }

    match /system/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
